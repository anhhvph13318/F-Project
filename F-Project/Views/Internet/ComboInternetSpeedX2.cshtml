            // Sự kiện chia sẻ Facebook
            $('#pShareFacebook').click(function () {
                const shareUrl = encodeURIComponent("");
                const facebookShareUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + shareUrl;
                window.open(facebookShareUrl, "Share Facebook", "_parent");
            });

            // Sự kiện chia sẻ Messenger
            $('#pShareMessenger').click(function () {
                var shareUrl = encodeURIComponent("");
                var redirectUri = "";
                if (isMobile()) {
                    // Trên mobile, mở ứng dụng Messenger hoặc Facebook Messenger
                    var messengerShareUrl = 'fb-messenger://share?link=' + shareUrl + '&app_id=5303202981&redirect_uri=' + redirectUri;
                    window.location.href = messengerShareUrl;  // Mở Messenger trực tiếp trên thiết bị di động
