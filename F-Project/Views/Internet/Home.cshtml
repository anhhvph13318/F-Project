    <script>
        /**
         * Use:
         * C1: Dùng true, false
         * C2: Dùng class 'shown', 'hiden'
         */
        function activeLoading(status = '') {
            //
            var sc_loading;
            if ($('.loading_c').length) {
                sc_loading = $('.loading_c');
                //
                if (typeof(status) == 'boolean') {
                    status == true ? sc_loading.show() : sc_loading.hide();
                } else {
                    if (status == "shown") {
                        sc_loading.addClass('shown');
                    } else {
                        sc_loading.removeClass('shown');
                        sc_loading.hide();
                    }
                }
            }
        }
