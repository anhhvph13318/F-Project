    <script>
        $(document).ready(function () {

            function showToast(content) {
                const referContent = $('#refer_toast').html();

                // Tạo div mới với nội dung đã sao chép
                const newToast = $('<div></div>')
                    .addClass('toast show')
                    .html(referContent);
                newToast.find('.toast-body').html(content);
                // Thêm div mới sau #refer_toast
                $('#refer_toast').after(newToast);

                newToast.click(function () {
                    $(this).closest('.toast').removeClass('show');
                });
                setTimeout(() => {
                    newToast.removeClass('show');
                }, 3000);
            }
            window.copyCode = function (idCP) {
                var copyText = document.getElementById(idCP);
                const toastEl = $('#refer_toast');
                const toastBody = $('#refer_toast .toast-body');
                if (!copyText) {
                    content = 'Không tìm thấy nội dung copy';
                    showToast(content);
                    return;
                }
                var textToCopy = copyText.innerText || copyText.textContent;

                // Kiểm tra trình duyệt có hỗ trợ `navigator.clipboard`
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    // Sử dụng clipboard API
                    navigator.clipboard.writeText(textToCopy).then(() => {
                        console.log("Đã copy mã giới thiệu: " + textToCopy);
                        content = "Đã copy thành công!";
                        showToast(content);
                    });
                } else {
                    var tempInput = document.createElement("textarea");
                    tempInput.value = textToCopy;
                    tempInput.style.position = "absolute";
                    tempInput.style.left = "-9999px"; // Ẩn phần tử
                    document.body.appendChild(tempInput);
                    tempInput.select();

                    try {
                        var successful = document.execCommand("copy");
                        if (successful) {
                            console.log("Đã copy mã giới thiệu: " + textToCopy);
                            content = "Đã copy thành công!";
                            showToast(content);
                        } else {
                            content = 'Copy thất bại, vui lòng thử lại';
                            showToast(content);
                        }
                    } catch (err) {
                        console.error("Lỗi sao chép:", err);
                        content = 'Copy thất bại, vui lòng thử lại';
                        showToast(content);
                    }
                    document.body.removeChild(tempInput);
                }
            };
            let downloadBtn = document.getElementById("btn_download_p");
            if (downloadBtn) {
                document.getElementById("btn_download_p").addEventListener("click", function () {
                    var canvas = document.querySelector('#p_qr_code_refer canvas');
                    if (canvas) {
                        const dataURL = canvas.toDataURL('image/png');

                        // Tạo thẻ <a> để tải file
                        const link = document.createElement('a');
                        link.href = dataURL;
                        link.download = 'qr_code.png'; // Tên file muốn tải
                        link.click();
                    }
                });
            }
            // const qrDiv = document.getElementById("p_qr_code_refer");
            // if (qrDiv) {
            // 	// Clear any existing QR code
            // 	qrDiv.innerHTML = "<div class='qrcode-scanner-l'></div><div class='qrcode-scanner'></div><div class='qrcode-scanner-r'></div>";
            // 	// Generate the QR code
            // 	var linkRefer = "";
            // 	QRCode.toCanvas(document.createElement('canvas'), linkRefer, {
            // 		width: 152,
            // 		margin: 2,
            // 	}, function (error, canvas) {
            // 		if (error) console.error("Error generating QR Code:", error);
            // 		else qrDiv.appendChild(canvas); // Append canvas to the div
            // 	});
            // }
            function isMobile() {
                return /Mobi|Android|iPhone/i.test(navigator.userAgent);
            }
            //appId: '5303202981', //27968228306157246 , 561777843334312, 1407297010246353
            // Sự kiện chia sẻ Facebook
            $('#pShareFacebook').click(function () {
                const shareUrl = encodeURIComponent("");
                const facebookShareUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + shareUrl;
                window.open(facebookShareUrl, "Share Facebook", "_parent");
            });

            // Sự kiện chia sẻ Messenger
            $('#pShareMessenger').click(function () {
                var shareUrl = encodeURIComponent("");
                var redirectUri = "";
                if (isMobile()) {
                    // Trên mobile, mở ứng dụng Messenger hoặc Facebook Messenger
                    var messengerShareUrl = 'fb-messenger://share?link=' + shareUrl + '&app_id=5303202981&redirect_uri=' + redirectUri;
                    window.location.href = messengerShareUrl;  // Mở Messenger trực tiếp trên thiết bị di động
                } else {
                    var messengerShareUrl = 'http://www.facebook.com/dialog/send?app_id=5303202981&display=popup&link=' + shareUrl + '&redirect_uri=' + redirectUri;
                    window.open(messengerShareUrl, "Share Messenger", "width=700,height=400");
                }
            });

            $('.modal button[aria-label="Close"]').on('click', function () {
                $.modal.close();
            });
        });

        window.openModalReferFriends = function (){
            $('#topbar-login-dropdown .dropdown').removeClass('open');

            $.ajax({
                url: "https://fpt.vn/get-refer-friend-detail",
                cache: false,
                type: "GET",
                dataType: "json",
                beforeSend: function () {
                    // show loading
                    activeLoading('shown');
                },
                success: function (data) {
                    if (data && data.data) {
                        // hide loading
                        activeLoading('hiden');
                        const referCode = data.data.referCode;
                        const referLink = data.data.referLink;
                        const qrLink = document.getElementById("p_refer_link");
                        const qrLinkShare = document.getElementById("refer_link_share");
                        const qrCode = document.getElementById("p_refer_code");
                        qrLink.innerHTML= referLink;
                        qrCode.innerHTML = referCode;
                        qrLinkShare.innerHTML = referLink;

                        const noCodeBox = $(".box-no-contract");
                        const hasCodeEl = $(".has-qr-code");
                        if(referLink ==''){
                            noCodeBox.removeClass('hidden');
                            hasCodeEl.addClass('hidden');
                        }else{
                            noCodeBox.addClass('hidden');
                            hasCodeEl.removeClass('hidden');
                            //
                            const qrDiv = document.getElementById("p_qr_code_refer");
                            if (qrDiv) {
                                // Clear any existing QR code
                                qrDiv.innerHTML = "<div class='qrcode-scanner-l'></div><div class='qrcode-scanner'></div><div class='qrcode-scanner-r'></div>";
                                // Generate the QR code
                                QRCode.toCanvas(document.createElement('canvas'), referLink, {
                                    width: 152,
                                    margin: 2,
                                }, function (error, canvas) {
                                    if (error) console.error("Error generating QR Code:", error);
                                    else qrDiv.appendChild(canvas); // Append canvas to the div
                                });
                            }
                        }
                        $('#modalReferFriends').modal({
                            escapeClose: false,
                            clickClose: false,
                            showClose: false
                        });
                    } else {
                        $('#modalReferFriendsError').modal({
                            escapeClose: false,
                            clickClose: false,
                            showClose: false
                        });
                    }
                },
                error: function (xhr, status, error) {
                    // hide loading
                    activeLoading('hiden');

                    $('#modalReferFriendsError').modal({
                        escapeClose: false,
                        clickClose: false,
                        showClose: false
                    });
                },
            });
        }


        function openModalShareRefer() {
            $.modal.close();
            $('#pShareQRModel').modal({
                escapeClose: false,
                clickClose: false,
                showClose: false,
                fadeDuration: 250 // tùy chọn animation
            });
        }
    </script>
