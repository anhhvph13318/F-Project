    <!-- Js process cookie popup -->
    <script>
        /**
         * Thông báo quản lý cookie & chính sách quyền riêng tư.
         * Cookie name: fptvn_ccp -> accepted | declined
         */
        document.addEventListener("DOMContentLoaded", function() {
            const popup = document.getElementById("fptvn_ccp_cookies_banner");
            const btnAccept = document.getElementById("fptvn_ccp_cookie_allow_all_btn");
            const btnDecline = document.getElementById("fptvn_ccp_cookie_refuse_btn");

            //
            const date = new Date();
            date.setMonth(date.getMonth() + 6); // cộng 6 tháng

            // Xử lý nút next/prev không reload nên ko thực hiện request HTTP
            const cookie = document.cookie.split('; ').find(row => row.startsWith('fptvn_ccp='));
            if (cookie && cookie.split('=')[1] === 'accepted') {
                popup?.classList.remove('shown');
            }

            //
            // if (!popup) return;
            if (popup) {
                // Thêm class để hiển thị có hiệu ứng
                popup.classList.add('shown');
            }

            // Đồng ý, lưu nửa năm
            if (btnAccept) {
                btnAccept.addEventListener("click", function() {
                    document.cookie = "fptvn_ccp=accepted; path=/; expires=" + date.toUTCString();
                    document.cookie = "fptvn_ccp_analytics=true; path=/; expires=" + date.toUTCString(); // bật analytics

                    // document.cookie = "fptvn_ccp=accepted; path=/; max-age=604800";
                    popup.style.display = "none";
                    //
                    location.reload();
                });
            }

            // Tu chối, luu 1 tuần roi hỏi lại
            if (btnDecline) {
                btnDecline.addEventListener("click", function() {
                    document.cookie = "fptvn_ccp=declined; path=/; max-age=604800";
                    document.cookie = "fptvn_ccp_analytics=false; path=/; max-age=604800";
                    popup.classList.remove('shown');
                    setTimeout(() => {
                        popup.style.display = "none";
                    }, 300);
                });
            }
        });
    </script>
