    <script type="text/javascript">
        let hostname = window.location.hostname;
        AT.init({
            "campaign_id": "236",
            "is_reoccur": 1,
            "is_lastclick": 1,
            "cookie_domain": '.' + hostname
        });
        AT.track();

        $( document ).ready(function() {
            Utm.extraTracking();
            Utm.getUtm();
        });

        const urlParams = new URLSearchParams(window.location.search);
        const ref = urlParams.get('ref');
        // Kiểm tra nếu 'ref' tồn tại, thì lưu vào sessionStorage
        if (ref) {
            sessionStorage.setItem('ref', ref);
        }

        function setCookie(name, value, days) {
            const date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000)); // Thời gian hết hạn
            const expires = "expires=" + date.toUTCString();
            const domain = "domain=." + window.location.hostname;

            document.cookie = name + "=" + value + ";" + expires + ";path=/;" + domain;
        }

        // Lấy giá trị 'click_id' từ URL
        const click_id = urlParams.get('click_id');
        // Nếu 'click_id' tồn tại, lưu vào cookie
        if (click_id) {
            console.log('click_id 1', click_id);
            setCookie('_aff_sid', click_id, 30); // Lưu cookie 30 ngày
        }

        // Lấy giá trị 'click_id' từ URL
        const aff_sid = urlParams.get('aff_sid');
        const utm_source = urlParams.get('utm_source');

        // Nếu 'click_id' tồn tại, lưu vào cookie
        if (aff_sid && utm_source === 'accesstrade') {
            console.log('_aff_sid 2', aff_sid);
            setCookie('_aff_network', 'accesstrade', 30);
            setCookie('_aff_sid', aff_sid, 30); // Lưu cookie 30 ngày
        }

        const keysToRemove = [
            'orderid', 'dataFields', 'selectedIndex', 'monthIndex', 'fsafeGoDataQrCode',
            'FSAFE_PAIDTYPE', 'IsAllowedUpdate', 'serviceCode', 'isStep',
            'INFO_CONTRACT_FSAFEGO', 'phoneNumber', 'isPageRegister', 'fsafeGoExtendDataQrCode',
            'listCateDetail', 'listExtra', 'indexCloud', 'indexMonthCloud', 'timeInstall',
            'dateInstall', 'listTimeZone', 'payloadApplyVoucher', 'cameraSessionData',
            'smarthomeSessionData', 'storageIsSendOtp', 'storageCountOtp', 'storageTime',
            'listDetailDisplay', 'cacheGetListExtra', 'cacheMainProduct', 'cachefindIndex',
            'cacheGiftKey', 'Appointment', 'settingASAPOption', 'selectedTimezone',
            'SaleTeamId', 'selectedService', 'ordercode20', 'isPage', 'isConfirmBackHome', 'AccessPointQty'
        ];

        keysToRemove.forEach(key => sessionStorage.removeItem(key));
        // console.log('Selected sessionStorage items removed.');


        // ------------------------ Xử lý aff_sid trong cookies và url (Đè button href nếu hardcode)
        // ------------------------ Usage: các button có "data-aff-clean" sẽ được chăm sóc
        (function () {

            function hasAffiliateCookie() {
                var cookies = document.cookie.split('; ');
                return cookies.some(function (c) {
                    return (
                        c.indexOf('_aff_sid=') === 0 ||
                        c.indexOf('_aff_network=') === 0
                    );
                });
            }

            function stripQuery(url) {
                try {
                    var u = new URL(url);
                    return u.origin + u.pathname;
                } catch (e) {
                    return url.split('?')[0];
                }
            }

            function initAffCleanButtons() {
                if (!hasAffiliateCookie()) return;

                var buttons = document.querySelectorAll('[data-aff-clean]');
                if (!buttons.length) return;

                buttons.forEach(function (btn) {
                    var href = btn.getAttribute('href');
                    if (!href) return;

                    btn.setAttribute('href', stripQuery(href));
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initAffCleanButtons);
            } else {
                initAffCleanButtons();
            }

        })();
        //------------------------ end ./. Xử lý aff_sid trong cookies và url (Đè button href nếu hardcode)
    </script>

